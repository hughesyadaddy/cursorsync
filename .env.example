# cursorsync configuration — copy to `.env` and fill in. `.env` is gitignored.
# NEVER put the Supabase service_role key here or anywhere in the repo. Client uses the anon key
# with Row Level Security; that is the only Supabase key cursorsync needs.

# Supabase project (Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# PowerSync instance (PowerSync dashboard -> instance URL)
POWERSYNC_URL=https://YOUR-INSTANCE.powersync.journeyapps.com

# Optional: override the Cursor global DB path (defaults to the per-OS standard location)
# CURSOR_DB_PATH=

# Phase 2: also sync agentKv content-addressed blobs (~12 GB). Off by default.
SYNC_AGENT_BLOBS=false
